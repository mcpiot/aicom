{
  "name": "uart-go",
  "version": "1.0.0",
  "description": "串口调试工具 - 仿MAC UI风格",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win:dir": "electron-builder --win --dir",
    "dist": "electron-builder --publish=never"
  },
  "keywords": [
    "serial",
    "uart",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "docx": "^9.6.1",
    "serialport": "^12.0.0"
  },
  "build": {
    "appId": "com.uartgo.app",
    "productName": "串口调试工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!build-guide.md",
      "!install-guide.md",
      "!README.md",
      "!**/*.{md,txt}",
      "!**/.git/**/*",
      "!**/.vscode/**/*",
      "!**/.idea/**/*",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!**/*.test.js",
      "!**/*.spec.js",
      "!**/node_modules/electron/**/*",
      "!**/node_modules/electron-builder/**/*"
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "mcpiotLogo_b.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "串口调试工具",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
